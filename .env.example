# Required: set a strong random secret for production
SECRET_KEY=replace-with-a-strong-random-secret

# Local SQLite by default (safe for demo)
DATABASE_URL=sqlite:///nuclei_webui.db

# Default admin bootstrap user (change before production use)
DEFAULT_ADMIN_USERNAME=Developer
DEFAULT_ADMIN_PASSWORD=change-this-password
DEFAULT_TENANT_ID=default

# Nuclei binary path
NUCLEI_BINARY=nuclei

# Optional custom template directory
# NUCLEI_TEMPLATES=/home/kali/nuclei-templates
